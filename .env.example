DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=inmobiliary_data

BOT_HEADLESS=true
BOT_MAX_PAGES=0
BOT_MAX_LISTINGS_PER_SOURCE=0
BOT_AUTO_SCAN=true
BOT_SCAN_ON_START=true
BOT_SCAN_INTERVAL_MINUTES=30
BOT_DELAY_MS=1500
BOT_CITY=Pasto
BOT_DEPARTMENT=Narino
BOT_STORAGE_DIR=./storage
BOT_DOWNLOAD_IMAGES=true
BOT_SAVE_EVIDENCE=true
BOT_SAVE_SCREENSHOTS=true

WEB_HOST=127.0.0.1
WEB_PORT=3000

# Facebook Marketplace puede requerir sesion valida del navegador.
# No se guardan credenciales en la BD. Si aplica, exporta storage state con Playwright.
FACEBOOK_STORAGE_STATE=

# Puedes sobrescribir URLs separandolas por coma si una fuente cambia estructura.
FINCARAIZ_URLS=
METROCUADRADO_URLS=
CIENCUADRAS_URLS=
AMOREL_URLS=
FACEBOOK_URLS=
