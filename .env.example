DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=inmobiliary_data
MYSQL_HOME=

BOT_HEADLESS=true
BOT_BROWSER_EXECUTABLE=
BOT_BROWSER_CHANNEL=
BOT_MAX_PAGES=0
BOT_MAX_LISTINGS_PER_SOURCE=0
BOT_SCAN_CONCURRENCY=3
BOT_SKIP_KNOWN_URLS=false
BOT_BLOCK_HEAVY_RESOURCES=true
BOT_AUTO_SCAN=true
BOT_SCAN_ON_START=true
BOT_SCAN_INTERVAL_MINUTES=30
BOT_DELAY_MS=1500
BOT_CITY=Pasto
BOT_DEPARTMENT=Narino
BOT_STORAGE_DIR=./storage
BOT_DOWNLOAD_IMAGES=false
BOT_MAX_IMAGES_PER_LISTING=5
BOT_IMAGE_DOWNLOAD_CONCURRENCY=3
BOT_SAVE_EVIDENCE=false
BOT_SAVE_SCREENSHOTS=false

WEB_HOST=127.0.0.1
WEB_PORT=3000

# Facebook Marketplace puede requerir sesion valida del navegador.
# No se guardan credenciales en la BD. Si aplica, exporta storage state con Playwright.
FACEBOOK_STORAGE_STATE=

# Puedes sobrescribir URLs separandolas por coma si una fuente cambia estructura.
FINCARAIZ_URLS=
METROCUADRADO_URLS=
CIENCUADRAS_URLS=
AMOREL_URLS=
