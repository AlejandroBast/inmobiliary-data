# Copiar a .env y completar. El .env no se versiona (ver .gitignore).
# DB_PASSWORD es obligatoria: los scripts fallan al arrancar si falta.

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=db_inmobiliary_data

# Facebook Marketplace usa 3301 por defecto si no defines DB_PORT.

# Reintentos de red (page.goto y descarga de imagenes).
# El backoff es exponencial: 2s, 4s, 8s...
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=2
